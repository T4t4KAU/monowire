set(MONOWIRE_VERSION      @MONOWIRE_INSTALL_VERSION@)
set(MONOWIRE_BUILD_COMMIT @MONOWIRE_BUILD_COMMIT@)
set(MONOWIRE_BUILD_NUMBER @MONOWIRE_BUILD_NUMBER@)
set(MONOWIRE_SHARED_LIB   @BUILD_SHARED_LIBS@)

@PACKAGE_INIT@

set_and_check(MONOWIRE_INCLUDE_DIR "@PACKAGE_MONOWIRE_INCLUDE_INSTALL_DIR@")
set_and_check(MONOWIRE_LIB_DIR     "@PACKAGE_MONOWIRE_LIB_INSTALL_DIR@")
set_and_check(MONOWIRE_BIN_DIR     "@PACKAGE_MONOWIRE_BIN_INSTALL_DIR@")

find_package(ggml REQUIRED HINTS ${MONOWIRE_LIB_DIR}/cmake)

find_library(monowire_LIBRARY monowire
    REQUIRED
    HINTS ${MONOWIRE_LIB_DIR}
    NO_CMAKE_FIND_ROOT_PATH
)

add_library(monowire UNKNOWN IMPORTED)
set_target_properties(monowire
    PROPERTIES
        INTERFACE_INCLUDE_DIRECTORIES "${MONOWIRE_INCLUDE_DIR}"
        INTERFACE_LINK_LIBRARIES "ggml::ggml;ggml::ggml-base;"
        IMPORTED_LINK_INTERFACE_LANGUAGES "CXX"
        IMPORTED_LOCATION "${monowire_LIBRARY}"
        INTERFACE_COMPILE_FEATURES c_std_90
        POSITION_INDEPENDENT_CODE ON)

check_required_components(Monowire)
